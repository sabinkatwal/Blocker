{
  "manifest_version": 3,
  "name": "FocusBlocker",
  "version": "1.0.0",
  "description": "Block distracting websites using timed sessions, notifications, and a modern interface.",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/main.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/main.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "notifications",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "blocked.html",
        "blocked.css",
        "blocked.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
